{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STALZONE Auction Watcher",
  "version": "0.1.0",
  "identifier": "com.artefactoptimizer.auction-watcher",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1430/tauri.html",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "STALZONE Auction Watcher",
        "url": "tauri.html",
        "width": 1360,
        "height": 840,
        "minWidth": 1060,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
